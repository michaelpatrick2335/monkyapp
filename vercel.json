{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/signup", "destination": "/api/handler" },
    { "source": "/api/login", "destination": "/api/handler" },
    { "source": "/api/unlock", "destination": "/api/handler" },
    { "source": "/api/logout", "destination": "/api/handler" },
    { "source": "/api/sessions", "destination": "/api/handler" },
    { "source": "/api/journal", "destination": "/api/handler" },
    { "source": "/api/session-complete", "destination": "/api/handler" },
    { "source": "/api/session/complete", "destination": "/api/handler" },
    { "source": "/api/challenge-complete", "destination": "/api/handler" },
    { "source": "/api/challenge/complete", "destination": "/api/handler" },
    { "source": "/api/change-level", "destination": "/api/handler" },
    { "source": "/api/music", "destination": "/api/handler" },
    { "source": "/api/music-active", "destination": "/api/handler" },
    { "source": "/api/music/active", "destination": "/api/handler" },
    { "source": "/api/voice", "destination": "/api/handler" },
    { "source": "/api/stripe-setup-intent", "destination": "/api/handler" },
    { "source": "/api/stripe/setup-intent", "destination": "/api/handler" },
    { "source": "/api/stripe-confirm-subscription", "destination": "/api/handler" },
    { "source": "/api/stripe/confirm-subscription", "destination": "/api/handler" },
    { "source": "/api/stripe-create-subscription", "destination": "/api/handler" },
    { "source": "/api/stripe/create-subscription", "destination": "/api/handler" },
    { "source": "/app/sw.js", "destination": "/app/sw.js" },
    { "source": "/app/manifest.json", "destination": "/app/manifest.json" },
    { "source": "/app/:path*", "destination": "/app/index.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/support", "destination": "/support.html" }
  ]
}
